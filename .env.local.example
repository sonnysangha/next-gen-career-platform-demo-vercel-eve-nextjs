# ─────────────────────────────────────────────────────────────
# CareerConnect — environment variables
# Copy to .env.local and fill in. Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Clerk Auth ──
# Create a Clerk application at https://go.clerk.com/sonny
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk route configuration (custom in-app pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/feed

# Only needed if Clerk webhooks are implemented (user sync)
# CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk Billing — the Pro plan id (looks like `cplan_...`).
# Clerk Dashboard → Billing → Plans → Pro → copy the plan id.
NEXT_PUBLIC_CLERK_PRO_PLAN_ID=cplan_xxx

# ── Convex ──
# Run `npx convex dev` once to generate these.
NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud
CONVEX_DEPLOYMENT=dev:xxx

# Clerk JWT issuer domain — used by convex/auth.config.ts.
# Clerk Dashboard → API Keys → "Frontend API URL" (starts with https://)
# Must ALSO be set on the Convex deployment:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-domain.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-domain.clerk.accounts.dev

# ── Vercel AI Gateway (powers the Eve agent — model: anthropic/claude-sonnet-5) ──
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=vck_xxx

# ── Eve ↔ Convex bridge ──
# Shared secret the Eve tools pass to Convex's secret-guarded api.eve.* functions.
# Generate any long random string, then ALSO set it on the Convex deployment:
#   npx convex env set EVE_CONVEX_SECRET <the-same-value>
EVE_CONVEX_SECRET=replace-with-a-long-random-string
